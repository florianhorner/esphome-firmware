# Copy this file to secrets.yaml and fill in your values
# secrets.yaml is gitignored and will not be committed

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# Home Assistant API encryption key (generate with: esphome wizard)
api_encryption_key: "REPLACE_WITH_BASE64_KEY"

# OTA password
ota_password: "REPLACE_WITH_OTA_PASSWORD"

# Fallback AP password (used when WiFi is unavailable)
fallback_ap_password: "REPLACE_WITH_FALLBACK_PASSWORD"
